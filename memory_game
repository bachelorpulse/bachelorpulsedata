<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Memory Sequence Game</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            max-width: 600px;
            width: 100%;
        }

        h1 {
            text-align: center;
            color: #667eea;
            margin-bottom: 10px;
            font-size: 2.5em;
        }

        .info-panel {
            display: flex;
            justify-content: space-around;
            margin-bottom: 30px;
            padding: 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 15px;
            color: white;
        }

        .info-item {
            text-align: center;
        }

        .info-label {
            font-size: 0.9em;
            opacity: 0.9;
            margin-bottom: 5px;
        }

        .info-value {
            font-size: 1.8em;
            font-weight: bold;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 8px;
            margin-bottom: 30px;
            aspect-ratio: 1;
        }

        .tile {
            background: #e0e0e0;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            border: 3px solid transparent;
            position: relative;
            overflow: hidden;
        }

        .tile:hover {
            transform: scale(1.05);
            border-color: #667eea;
        }

        .tile.highlighted {
            background: linear-gradient(135deg, #ffd89b 0%, #19547b 100%);
            box-shadow: 0 0 20px rgba(255, 216, 155, 0.8);
            animation: pulse 0.5s ease;
        }

        .tile.correct {
            background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
            border-color: #11998e;
        }

        .tile.wrong {
            background: linear-gradient(135deg, #ee0979 0%, #ff6a00 100%);
            animation: shake 0.5s ease;
        }

        .tile.disabled {
            pointer-events: none;
            opacity: 0.6;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            75% { transform: translateX(10px); }
        }

        .controls {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-bottom: 20px;
        }

        button {
            padding: 15px 40px;
            font-size: 1.1em;
            font-weight: bold;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            color: white;
        }

        .start-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .start-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        .start-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .reset-btn {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        }

        .reset-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(245, 87, 108, 0.4);
        }

        .message {
            text-align: center;
            font-size: 1.2em;
            min-height: 30px;
            color: #667eea;
            font-weight: bold;
            animation: fadeIn 0.5s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .success {
            color: #11998e;
        }

        .error {
            color: #ee0979;
        }

        @media (max-width: 600px) {
            .container {
                padding: 20px;
            }

            h1 {
                font-size: 2em;
            }

            .grid {
                gap: 5px;
            }

            button {
                padding: 12px 30px;
                font-size: 1em;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Memory Sequence</h1>
        
        <div class="info-panel">
            <div class="info-item">
                <div class="info-label">Level</div>
                <div class="info-value" id="level">1</div>
            </div>
            <div class="info-item">
                <div class="info-label">Score</div>
                <div class="info-value" id="score">0</div>
            </div>
            <div class="info-item">
                <div class="info-label">Tiles</div>
                <div class="info-value" id="tileCount">3</div>
            </div>
        </div>

        <div class="grid" id="grid"></div>

        <div class="controls">
            <button class="start-btn" id="startBtn">Start Game</button>
            <button class="reset-btn" id="resetBtn">Reset</button>
        </div>

        <div class="message" id="message">Click "Start Game" to begin!</div>
    </div>

    <script>
        const GRID_SIZE = 6;
        const TOTAL_TILES = GRID_SIZE * GRID_SIZE;
        const FLASH_DURATION = 500;
        const FLASH_INTERVAL = 600;

        let level = 1;
        let score = 0;
        let pattern = [];
        let selectedTiles = [];
        let gameActive = false;
        let isShowingPattern = false;

        const grid = document.getElementById('grid');
        const startBtn = document.getElementById('startBtn');
        const resetBtn = document.getElementById('resetBtn');
        const levelDisplay = document.getElementById('level');
        const scoreDisplay = document.getElementById('score');
        const tileCountDisplay = document.getElementById('tileCount');
        const messageDisplay = document.getElementById('message');

        // Initialize grid
        function initGrid() {
            grid.innerHTML = '';
            for (let i = 0; i < TOTAL_TILES; i++) {
                const tile = document.createElement('div');
                tile.className = 'tile';
                tile.dataset.index = i;
                tile.addEventListener('click', handleTileClick);
                grid.appendChild(tile);
            }
        }

        // Generate random pattern
        function generatePattern() {
            const numTiles = Math.min(2 + level, 15); // Starts at 3, max 15
            pattern = [];
            const availableIndices = Array.from({length: TOTAL_TILES}, (_, i) => i);
            
            for (let i = 0; i < numTiles; i++) {
                const randomIndex = Math.floor(Math.random() * availableIndices.length);
                pattern.push(availableIndices[randomIndex]);
                availableIndices.splice(randomIndex, 1);
            }
            
            tileCountDisplay.textContent = numTiles;
        }

        // Show pattern to player
        async function showPattern() {
            isShowingPattern = true;
            disableAllTiles();
            messageDisplay.textContent = 'Memorize the pattern...';
            
            // Flash all pattern tiles simultaneously
            const tiles = document.querySelectorAll('.tile');
            
            // Show pattern
            pattern.forEach(index => {
                tiles[index].classList.add('highlighted');
            });

            await sleep(2000 + (level * 200)); // Show longer as levels increase

            // Hide pattern
            pattern.forEach(index => {
                tiles[index].classList.remove('highlighted');
            });

            await sleep(500);

            isShowingPattern = false;
            enableAllTiles();
            messageDisplay.textContent = 'Now click the tiles you remember!';
        }

        // Handle tile click
        function handleTileClick(e) {
            if (!gameActive || isShowingPattern) return;

            const tile = e.target;
            const index = parseInt(tile.dataset.index);

            if (selectedTiles.includes(index)) return;

            selectedTiles.push(index);

            if (pattern.includes(index)) {
                tile.classList.add('correct');
                
                if (selectedTiles.length === pattern.length) {
                    setTimeout(() => levelComplete(), 500);
                }
            } else {
                tile.classList.add('wrong');
                gameOver();
            }
        }

        // Level complete
        function levelComplete() {
            gameActive = false;
            const levelScore = pattern.length * 10;
            score += levelScore;
            scoreDisplay.textContent = score;
            
            messageDisplay.textContent = `Level ${level} Complete! +${levelScore} points`;
            messageDisplay.className = 'message success';
            
            level++;
            levelDisplay.textContent = level;
            
            setTimeout(() => {
                startBtn.textContent = 'Next Level';
                startBtn.disabled = false;
            }, 1500);
        }

        // Game over
        function gameOver() {
            gameActive = false;
            disableAllTiles();
            messageDisplay.textContent = `Game Over! Final Score: ${score}`;
            messageDisplay.className = 'message error';
            
            // Show correct pattern
            const tiles = document.querySelectorAll('.tile');
            setTimeout(() => {
                pattern.forEach(index => {
                    tiles[index].classList.add('highlighted');
                });
            }, 1000);

            setTimeout(() => {
                startBtn.textContent = 'Start New Game';
                startBtn.disabled = false;
            }, 3000);
        }

        // Start game
        async function startGame() {
            if (startBtn.textContent === 'Start New Game') {
                resetGame();
            }

            clearBoard();
            selectedTiles = [];
            gameActive = true;
            startBtn.disabled = true;
            messageDisplay.className = 'message';
            
            generatePattern();
            await showPattern();
        }

        // Reset game
        function resetGame() {
            level = 1;
            score = 0;
            levelDisplay.textContent = level;
            scoreDisplay.textContent = score;
            tileCountDisplay.textContent = 3;
            clearBoard();
            selectedTiles = [];
            gameActive = false;
            messageDisplay.textContent = 'Click "Start Game" to begin!';
            messageDisplay.className = 'message';
            startBtn.textContent = 'Start Game';
            startBtn.disabled = false;
        }

        // Clear board
        function clearBoard() {
            const tiles = document.querySelectorAll('.tile');
            tiles.forEach(tile => {
                tile.className = 'tile';
            });
        }

        // Utility functions
        function disableAllTiles() {
            document.querySelectorAll('.tile').forEach(tile => {
                tile.classList.add('disabled');
            });
        }

        function enableAllTiles() {
            document.querySelectorAll('.tile').forEach(tile => {
                tile.classList.remove('disabled');
            });
        }

        function sleep(ms) {
            return new Promise(resolve => setTimeout(resolve, ms));
        }

        // Event listeners
        startBtn.addEventListener('click', startGame);
        resetBtn.addEventListener('click', resetGame);

        // Initialize
        initGrid();
    </script>
</body>
</html>
