[
  { "q": "In the algebraic expression 3x + 5, what is the 'variable'?", "o": ["3", "5", "x", "3x"], "a": 2, "sol": "A variable is a symbol, usually a letter, that represents an unknown value; here it is 'x'." },
  { "q": "What is the coefficient of y in the expression -7y + 2?", "o": ["7", "-7", "2", "y"], "a": 1, "sol": "The coefficient is the numerical factor of a term; for -7y, it is -7." },
  { "q": "In a 2-digit number 'pq', how is its value expressed in generalized form?", "o": ["p + q", "10p + q", "10q + p", "pq"], "a": 1, "sol": "The digit 'p' is in the tens place (10*p) and 'q' is in the ones place." },
  { "q": "If 'abc' is a 3-digit number, which of the following represents its value?", "o": ["100a + 10b + c", "a + b + c", "100c + 10b + a", "10a + 10b + 10c"], "a": 0, "sol": "In a 3-digit number, the places are hundreds (100a), tens (10b), and ones (c)." },
  { "q": "What is the result of adding 2x and 3x?", "o": ["5", "6x", "5x", "5x²"], "a": 2, "sol": "Like terms are added by summing their coefficients: 2 + 3 = 5, so 5x." },
  { "q": "Which of these is a 'monomial'?", "o": ["x + y", "3xyz", "a - b", "x² + 2x + 1"], "a": 1, "sol": "A monomial is an algebraic expression containing only one term." },
  { "q": "The product of (x + 2) and (x + 3) is:", "o": ["x² + 5x + 6", "x² + 6", "2x + 5", "x² + 6x + 5"], "a": 0, "sol": "Using (x+a)(x+b) = x² + (a+b)x + ab gives x² + (2+3)x + (2*3) = x² + 5x + 6." },
  { "q": "Simplify: 10a - 4a + 2a", "o": ["4a", "8a", "12a", "6a"], "a": 1, "sol": "10 - 4 + 2 = 8, so the result is 8a." },
  { "q": "If x = 2, what is the value of 3x² - 5?", "o": ["1", "7", "11", "12"], "a": 1, "sol": "3(2²) - 5 = 3(4) - 5 = 12 - 5 = 7." },
  { "q": "What do we call an equality that is true for every value of the variable?", "o": ["Equation", "Identity", "Expression", "Variable"], "a": 1, "sol": "An identity is an equality that holds true regardless of the values chosen for its variables." },
  { "q": "The identity (a + b)² is equal to:", "o": ["a² + b²", "a² + 2ab + b²", "a² - 2ab + b²", "2a + 2b"], "a": 1, "sol": "Standard algebraic identity: (a+b)(a+b) = a² + ab + ba + b² = a² + 2ab + b²." },
  { "q": "The value of (x - y)² is:", "o": ["x² - y²", "x² + y² - 2xy", "x² + y²", "x² - y² + 2xy"], "a": 1, "sol": "Standard identity: (a-b)² = a² - 2ab + b²." },
  { "q": "Expand (2x + 3y)²:", "o": ["4x² + 9y²", "4x² + 6xy + 9y²", "4x² + 12xy + 9y²", "2x² + 12xy + 3y²"], "a": 2, "sol": "(2x)² + 2(2x)(3y) + (3y)² = 4x² + 12xy + 9y²." },
  { "q": "Evaluate (a + b)(a - b):", "o": ["a² + b²", "a² - b²", "2a - 2b", "a² - 2ab + b²"], "a": 1, "sol": "This is the difference of squares identity." },
  { "q": "What is (99)² calculated using identities?", "o": ["(100 - 1)²", "(90 + 9)²", "(98 + 1)²", "Both A and B"], "a": 3, "sol": "While both work, (100-1)² is the most efficient application of (a-b)²." },
  { "q": "The value of 103 × 97 is:", "o": ["10000", "9991", "9999", "10009"], "a": 1, "sol": "(100 + 3)(100 - 3) = 100² - 3² = 10000 - 9 = 9991." },
  { "q": "Which of the following is a binomial?", "o": ["5x²yz", "x + y + z", "3x - 7", "4"], "a": 2, "sol": "A binomial has exactly two terms." },
  { "q": "Subtract (a - b) from (a + b):", "o": ["2a", "2b", "0", "2a + 2b"], "a": 1, "sol": "(a + b) - (a - b) = a + b - a + b = 2b." },
  { "q": "What is the degree of the polynomial 4x³ - 2x² + 5?", "o": ["1", "2", "3", "0"], "a": 2, "sol": "The degree is the highest power of the variable in the expression." },
  { "q": "Find the product: 4ab × 3a²b", "o": ["12a²b²", "7a³b²", "12a³b²", "12ab"], "a": 2, "sol": "(4*3) * (a*a²) * (b*b) = 12a³b²." },
  { "q": "The area of a rectangle with length 5x and breadth 3y is:", "o": ["8xy", "15xy", "15x+y", "15x²y²"], "a": 1, "sol": "Area = Length × Breadth = 5x × 3y = 15xy." },
  { "q": "What is the volume of a rectangular box with dimensions 2x, 3y, and 5z?", "o": ["10xyz", "30xyz", "15xyz", "30x+y+z"], "a": 1, "sol": "Volume = l × b × h = 2x × 3y × 5z = 30xyz." },
  { "q": "The term 'Like Terms' refers to terms having the same:", "o": ["Coefficients", "Signs", "Algebraic factors", "Numbers"], "a": 2, "sol": "Terms like 2x and 5x are 'like' because they share the variable 'x' to the same power." },
  { "q": "Simplify: (x + y) - (x - y)", "o": ["0", "2x", "2y", "-2y"], "a": 2, "sol": "x + y - x + y = 2y." },
  { "q": "Which identity is best to solve 51²?", "o": ["(a+b)²", "(a-b)²", "(a+b)(a-b)", "(x+a)(x+b)"], "a": 0, "sol": "51² = (50 + 1)² uses the (a+b)² identity easily." },
  { "q": "If we multiply a monomial by a trinomial, the result has how many terms?", "o": ["1", "2", "3", "4"], "a": 2, "sol": "Each of the 3 terms in the trinomial is multiplied by the monomial, resulting in 3 terms." },
  { "q": "The value of 1.1m × 1.1m is:", "o": ["1.21m", "1.21m²", "2.2m", "12.1m²"], "a": 1, "sol": "1.1 * 1.1 = 1.21, and m * m = m²." },
  { "q": "In the expression 4x²y, the factors are:", "o": ["4, x, y", "4, x, x, y", "4x, y", "4, x², y"], "a": 1, "sol": "The irreducible factors are 4, x, x, and y." },
  { "q": "Solve for x: 2x - 10 = 0", "o": ["2", "10", "5", "-5"], "a": 2, "sol": "2x = 10, so x = 10/2 = 5." },
  { "q": "Using identity, (x + 3)(x + 7) equals:", "o": ["x² + 10x + 21", "x² + 21", "x² + 4x + 21", "x² + 21x + 10"], "a": 0, "sol": "x² + (3+7)x + (3*7) = x² + 10x + 21." },
  { "q": "If p = -1, find the value of 4p + 7.", "o": ["11", "3", "-3", "4"], "a": 1, "sol": "4(-1) + 7 = -4 + 7 = 3." },
  { "q": "The value of (7a - 9b)² is:", "o": ["49a² - 81b²", "49a² + 81b² - 126ab", "49a² + 81b²", "49a² - 126ab - 81b²"], "a": 1, "sol": "Using (a-b)²: (7a)² - 2(7a)(9b) + (9b)² = 49a² - 126ab + 81b²." },
  { "q": "A symbol which can take various numerical values is called a:", "o": ["Constant", "Variable", "Term", "Expression"], "a": 1, "sol": "This is the definition of a variable." },
  { "q": "The numerical factor of a term is its:", "o": ["Variable", "Constant", "Coefficient", "Degree"], "a": 2, "sol": "Example: In 5x, 5 is the numerical coefficient." },
  { "q": "How many terms are in the expression 5x² - 2x + 7?", "o": ["1", "2", "3", "4"], "a": 2, "sol": "The terms are 5x², -2x, and 7." },
  { "q": "Find the product of (a²)(2a²²)(4a²⁶):", "o": ["8a⁵⁰", "6a⁵⁰", "8a⁴⁸", "12a⁵⁰"], "a": 0, "sol": "(1*2*4) * a^(2+22+26) = 8a⁵⁰." },
  { "q": "The identity for (x + a)(x + b) is:", "o": ["x² + ab", "x² + (a+b)x + ab", "x² + ax + b", "x² + (a-b)x - ab"], "a": 1, "sol": "Standard identity used for binomial multiplication." },
  { "q": "What is the value of 105² - 5²?", "o": ["10000", "11000", "11025", "1050"], "a": 1, "sol": "(105+5)(105-5) = 110 * 100 = 11000." },
  { "q": "The square of a monomial is always a:", "o": ["Monomial", "Binomial", "Trinomial", "Constant"], "a": 0, "sol": "(axⁿ)² = a²x²ⁿ, which is still one term." },
  { "q": "If the sum of digits of a 2-digit number 'ab' is subtracted from the number, the result is:", "o": ["9a", "9b", "10a", "a+b"], "a": 0, "sol": "(10a + b) - (a + b) = 9a." },
  { "q": "Algebraic expressions are formed from:", "o": ["Variables only", "Constants only", "Variables and constants", "None"], "a": 2, "sol": "Expressions combine variables and constants using operations." },
  { "q": "What is the value of (z + 1)(z - 1)?", "o": ["z² + 1", "z² - 1", "2z", "z² - 2z + 1"], "a": 1, "sol": "Difference of squares: a² - b²." },
  { "q": "Simplify 3x(4x - 5) + 3 for x = 3:", "o": ["66", "21", "18", "63"], "a": 0, "sol": "3(3)[4(3)-5] + 3 = 9[12-5] + 3 = 9(7) + 3 = 63 + 3 = 66." },
  { "q": "Add: 7xy + 5yz - 3zx, 4yz + 9zx - 4y, -3xz + 5x - 2xy", "o": ["5xy + 9yz + 3zx + 5x - 4y", "5xy - 9yz + 3zx", "5x - 4y", "7xy + 9yz"], "a": 0, "sol": "Combine like terms: (7-2)xy + (5+4)yz + (-3+9-3)zx + 5x - 4y." },
  { "q": "The product of a positive and a negative term is:", "o": ["Positive", "Negative", "Zero", "Depends on values"], "a": 1, "sol": "(+) * (-) = (-)." },
  { "q": "What is the coefficient of x² in the expression 1 - x²?", "o": ["1", "0", "-1", "x"], "a": 2, "sol": "The term is -x², so the coefficient is -1." },
  { "q": "Find the value of (x - 5)(x + 5) at x = 10:", "o": ["25", "75", "100", "50"], "a": 1, "sol": "10² - 5² = 100 - 25 = 75." },
  { "q": "The expression x/y + y/x is a:", "o": ["Monomial", "Binomial", "Trinomial", "Not a polynomial"], "a": 1, "sol": "It has two terms, hence a binomial." },
  { "q": "If a = 1, b = 2, find a² + b² + 2ab.", "o": ["5", "9", "3", "7"], "a": 1, "sol": "(a+b)² = (1+2)² = 3² = 9." },
  { "q": "Subtract 3xy + 5yz from 7xy - 2yz:", "o": ["4xy - 7yz", "10xy + 3yz", "4xy + 3yz", "4xy - 3yz"], "a": 0, "sol": "(7xy - 2yz) - (3xy + 5yz) = 4xy - 7yz." },
  { "q": "What is the product of (0.2x) and (0.3x)?", "o": ["0.6x²", "0.06x²", "0.06x", "0.5x²"], "a": 1, "sol": "0.2 * 0.3 = 0.06." },
  { "q": "The generalized form of a 4-digit number 'abcd' is:", "o": ["1000a+100b+10c+d", "a+b+c+d", "1000d+100c+10b+a", "10a+10b+10c+10d"], "a": 0, "sol": "Standard place value expansion." },
  { "q": "Evaluate 102 × 103 using (x+a)(x+b):", "o": ["10506", "10606", "10006", "11006"], "a": 0, "sol": "100² + (2+3)100 + 2*3 = 10000 + 500 + 6 = 10506." },
  { "q": "The value of (a-b)² + 2ab is:", "o": ["a² - b²", "a² + b²", "a² + b² + 4ab", "0"], "a": 1, "sol": "a² - 2ab + b² + 2ab = a² + b²." },
  { "q": "What is the product of (x + 1/x) and (x - 1/x)?", "o": ["x² + 1/x²", "x² - 1/x²", "x² - 1", "1"], "a": 1, "sol": "Difference of squares." },
  { "q": "An expression with four terms is called a:", "o": ["Binomial", "Trinomial", "Polynomial", "Monomial"], "a": 2, "sol": "Polynomial is a general term for expressions with one or more terms." },
  { "q": "Find the area of a square with side length 2m²n.", "o": ["4m²n²", "4m⁴n²", "2m⁴n²", "4m²n"], "a": 1, "sol": "(2m²n)² = 4m⁴n²." },
  { "q": "The product of (a-b) and (b-a) is:", "o": ["a² - b²", "-(a-b)²", "(a-b)²", "0"], "a": 1, "sol": "(a-b) * -1 * (a-b) = -(a-b)²." },
  { "q": "The value of (10.5)² - (9.5)² is:", "o": ["1", "20", "10", "100"], "a": 1, "sol": "(10.5+9.5)(10.5-9.5) = 20 * 1 = 20." },
  { "q": "The identity (x+a)(x+b) = x² + (a+b)x + ab is true for:", "o": ["Only positive x", "Only integers", "All values of x, a, b", "Only x=0"], "a": 2, "sol": "Identities are universally true for all variable values." },
  { "q": "Simplify: a(b - c) + b(c - a) + c(a - b)", "o": ["abc", "ab+bc+ca", "0", "a+b+c"], "a": 2, "sol": "ab - ac + bc - ab + ac - bc = 0." },
  { "q": "What is the coefficient of x in the expansion of (x + 5)²?", "o": ["5", "10", "25", "1"], "a": 1, "sol": "x² + 2(5)x + 25 = x² + 10x + 25." },
  { "q": "The constant term in 3x² - 5x + 9 is:", "o": ["3", "-5", "9", "x"], "a": 2, "sol": "The constant term is the one without a variable." },
  { "q": "If x + 1/x = 5, then x² + 1/x² is:", "o": ["25", "27", "23", "10"], "a": 2, "sol": "(x + 1/x)² - 2 = 5² - 2 = 23." },
  { "q": "Multiply -4p and (q + r):", "o": ["-4pq + r", "-4pq - 4pr", "4pq + 4pr", "-4pqr"], "a": 1, "sol": "Distribute -4p to both terms inside the bracket." },
  { "q": "Find product: (2/3 xy) × (9/10 x²y²)", "o": ["3/5 x³y³", "1/2 x³y³", "18/30 xy", "3/5 x²y²"], "a": 0, "sol": "(2/3 * 9/10) = 18/30 = 3/5. Powers add up." },
  { "q": "What is the square of 3x - 4y?", "o": ["9x² - 16y²", "9x² + 16y² - 24xy", "9x² + 16y²", "6x² - 8y²"], "a": 1, "sol": "(3x)² - 2(3x)(4y) + (4y)²." },
  { "q": "The value of 25x² - 10x + 1 when x = 1/5 is:", "o": ["1", "0", "5", "2"], "a": 1, "sol": "It is (5x-1)². For x=1/5, (5(1/5)-1)² = (1-1)² = 0." },
  { "q": "Like terms in 7x, 5y, -3x, 12z are:", "o": ["7x, 5y", "7x, -3x", "5y, 12z", "None"], "a": 1, "sol": "They both have the variable 'x'." },
  { "q": "The identity (a+b)² - (a-b)² equals:", "o": ["2a² + 2b²", "4ab", "0", "2ab"], "a": 1, "sol": "(a² + 2ab + b²) - (a² - 2ab + b²) = 4ab." },
  { "q": "Value of (a + b)² + (a - b)² is:", "o": ["2(a² + b²)", "4ab", "2a²", "2b²"], "a": 0, "sol": "(a² + 2ab + b²) + (a² - 2ab + b²) = 2a² + 2b²." },
  { "q": "A binomial multiplied by a binomial gives at most how many terms before simplification?", "o": ["2", "3", "4", "1"], "a": 2, "sol": "(a+b)(c+d) = ac + ad + bc + bd." },
  { "q": "Solve: 5x/2 = 25", "o": ["5", "10", "20", "50"], "a": 1, "sol": "5x = 50, x = 10." },
  { "q": "Which expression is equivalent to (x+3)²?", "o": ["x²+9", "x²+6x+9", "x²+3x+9", "2x+6"], "a": 1, "sol": "Square of a sum formula." },
  { "q": "If x=0, the value of 5x² - 3x + 10 is:", "o": ["0", "10", "5", "-3"], "a": 1, "sol": "All terms with x become 0, leaving only 10." },
  { "q": "The expansion of (x-1)(x+1)(x²+1) is:", "o": ["x⁴-1", "x⁴+1", "(x-1)⁴", "x²-1"], "a": 0, "sol": "(x²-1)(x²+1) = x⁴-1." },
  { "q": "The expression p² + q² + r² - 3pqr is a:", "o": ["Binomial", "Trinomial", "Polynomial", "Monomial"], "a": 2, "sol": "It has 4 terms." },
  { "q": "Find the product: (a+b)(0):", "o": ["a+b", "0", "ab", "1"], "a": 1, "sol": "Any expression multiplied by zero is zero." },
  { "q": "If y = -2, find value of y³:", "o": ["8", "-8", "4", "-4"], "a": 1, "sol": "(-2) * (-2) * (-2) = -8." },
  { "q": "Simplify: 2x²(x + 1) - x", "o": ["2x³ + 2x² - x", "2x² + x", "2x³ + x", "3x² + x"], "a": 0, "sol": "2x²*x + 2x²*1 - x = 2x³ + 2x² - x." },
  { "q": "Find the square of 10.2 using identity:", "o": ["104.04", "104.4", "100.4", "104.02"], "a": 0, "sol": "(10 + 0.2)² = 100 + 4 + 0.04 = 104.04." },
  { "q": "What must be added to x² + y² to make it (x+y)²?", "o": ["xy", "2xy", "-2xy", "x+y"], "a": 1, "sol": "(x+y)² = x² + y² + 2xy." },
  { "q": "Find the value of (998)² - (4) using a²-b²:", "o": ["996000", "996004", "1000000", "994000"], "a": 0, "sol": "(998+2)(998-2) = 1000 * 996 = 996000." },
  { "q": "If x - 1/x = 3, then x² + 1/x² is:", "o": ["9", "7", "11", "5"], "a": 2, "sol": "(x-1/x)² + 2 = 3² + 2 = 11." },
  { "q": "Product of (x+2)(x-3):", "o": ["x²-x-6", "x²-5x-6", "x²+x-6", "x²-6"], "a": 0, "sol": "x² + (2-3)x + (2*-3) = x² - x - 6." },
  { "q": "Volume of a cube with side 3a:", "o": ["9a²", "27a³", "27a", "9a³"], "a": 1, "sol": "(3a)³ = 27a³." },
  { "q": "Coefficient of ab in (a+b)² is:", "o": ["1", "2", "0", "a"], "a": 1, "sol": "Expansion is a² + 2ab + b²." },
  { "q": "Simplify: (a+b)² - 2ab", "o": ["a²+b²", "a²-b²", "(a-b)²", "0"], "a": 0, "sol": "Standard reduction." },
  { "q": "Is x² + 5x + 6 = (x+2)(x+3) an identity?", "o": ["Yes", "No", "Only for x=1", "Only for x=0"], "a": 0, "sol": "It is true for all values of x." },
  { "q": "Find (x-y)(x+y)(x²+y²):", "o": ["x⁴-y⁴", "x⁴+y⁴", "(x-y)⁴", "x²-y²"], "a": 0, "sol": "(x²-y²)(x²+y²) = x⁴-y⁴." },
  { "q": "Value of 49² using (a-b)²:", "o": ["2401", "2501", "2499", "2301"], "a": 0, "sol": "(50-1)² = 2500 - 100 + 1 = 2401." },
  { "q": "Value of 5.2 × 4.8:", "o": ["24.96", "25", "24.04", "24.84"], "a": 0, "sol": "(5 + 0.2)(5 - 0.2) = 25 - 0.04 = 24.96." },
  { "q": "Terms of 4x² - 3xy are:", "o": ["4x², 3xy", "4x², -3xy", "4, -3", "x², xy"], "a": 1, "sol": "Terms include the sign." },
  { "q": "If x=2, y=1, find x² - y².", "o": ["1", "3", "5", "0"], "a": 1, "sol": "4 - 1 = 3." },
  { "q": "In 'Algebra Play', x + x + x is:", "o": ["x³", "3x", "x+3", "3+x"], "a": 1, "sol": "Repeated addition is multiplication." },
  { "q": "Square of 0.4:", "o": ["1.6", "0.16", "0.016", "0.8"], "a": 1, "sol": "0.4 * 0.4 = 0.16." },
  { "q": "Factorize x² - 9:", "o": ["(x-3)²", "(x+3)²", "(x-3)(x+3)", "x(x-9)"], "a": 2, "sol": "Difference of squares." },
  { "q": "If (x+1) is a factor of x² + kx + 1, find k for k to be 2:", "o": ["1", "2", "3", "0"], "a": 1, "sol": "For (x+1)² = x²+2x+1, k must be 2." },
  { "q": "Which expression represents: 'Thrice a number squared minus five'?", "o": ["(3x)² - 5", "3x² - 5", "3(x-5)²", "3x - 5²"], "a": 1, "sol": "Order of operations: square first, then triple, then subtract." },
  { "q": "The product of (x+y), (y+z) and (0) is:", "o": ["xyz", "x+y+z", "0", "1"], "a": 2, "sol": "Multiplication by zero results in zero." }
]
