[
  { "q": "In the expression x(y + z) = xy + xz, which property is being demonstrated?", "o": ["Commutative Property", "Distributive Property", "Associative Property", "Closure Property"], "a": 1, "sol": "The distributive property states that multiplying a sum by a number is the same as multiplying each addend by the number and then adding the products." },
  { "q": "What is the product of 3x and (4x + 5)?", "o": ["12x^2 + 15x", "12x + 15", "7x^2 + 8x", "12x^2 + 5"], "a": 0, "sol": "Multiply 3x by each term: 3x * 4x = 12x^2 and 3x * 5 = 15x." },
  { "q": "Simplify the expression: a(a - b) + b(a - b).", "o": ["a^2 + b^2", "a^2 - b^2", "2ab", "a^2 - 2ab + b^2"], "a": 1, "sol": "a^2 - ab + ba - b^2 = a^2 - b^2 (since ab = ba)." },
  { "q": "The area of a rectangle with length 2x and breadth (3x + 4) is:", "o": ["5x + 4", "6x^2 + 8x", "6x^2 + 4", "6x + 8"], "a": 1, "sol": "Area = Length * Breadth = 2x(3x + 4) = 6x^2 + 8x." },
  { "q": "What do we get when we multiply (x + 2) by (x + 3)?", "o": ["x^2 + 5x + 6", "x^2 + 6x + 5", "x^2 + 5", "2x + 5"], "a": 0, "sol": "x(x+3) + 2(x+3) = x^2 + 3x + 2x + 6 = x^2 + 5x + 6." },
  { "q": "Multiply 5xy by (x^2 - y^2).", "o": ["5x^3y - 5xy^3", "5x^2y - 5xy^2", "5x^3 - 5y^3", "10x^2y^2"], "a": 0, "sol": "5xy * x^2 = 5x^3y and 5xy * (-y^2) = -5xy^3." },
  { "q": "What is the value of 102 * 98 using the identity (a+b)(a-b) = a^2 - b^2?", "o": ["10000", "9996", "9994", "9804"], "a": 1, "sol": "(100 + 2)(100 - 2) = 100^2 - 2^2 = 10000 - 4 = 9996." },
  { "q": "The product of a monomial and a binomial is always a:", "o": ["Monomial", "Binomial", "Trinomial", "Constant"], "a": 1, "sol": "Distributing a single term over two terms generally results in two terms (a binomial)." },
  { "q": "Multiply (2a + 3b) and (2a - 3b).", "o": ["4a^2 + 9b^2", "4a^2 - 9b^2", "4a^2 - 6ab + 9b^2", "2a^2 - 3b^2"], "a": 1, "sol": "Using (x+y)(x-y) = x^2 - y^2, we get (2a)^2 - (3b)^2 = 4a^2 - 9b^2." },
  { "q": "If we distribute -2 over (x - 4), the result is:", "o": ["-2x - 8", "-2x + 8", "2x - 8", "-2x - 4"], "a": 1, "sol": "-2 * x = -2x and -2 * -4 = +8." },
  { "q": "Evaluate (x + 5)^2 using algebraic identities.", "o": ["x^2 + 25", "x^2 + 10x + 25", "x^2 + 5x + 25", "2x + 10"], "a": 1, "sol": "(a+b)^2 = a^2 + 2ab + b^2. Here x^2 + 2(x)(5) + 5^2 = x^2 + 10x + 25." },
  { "q": "What is the product of 0.5x and 2y?", "o": ["x + y", "xy", "0.1xy", "10xy"], "a": 1, "sol": "0.5 * 2 = 1, so the product is 1xy or xy." },
  { "q": "Multiply (p - q) by (p + q + r).", "o": ["p^2 - q^2 + pr - qr", "p^2 + q^2 + r^2", "p^2 - q^2", "p^2 - q^2 - r^2"], "a": 0, "sol": "p(p+q+r) - q(p+q+r) = p^2 + pq + pr - qp - q^2 - qr = p^2 - q^2 + pr - qr." },
  { "q": "The coefficient of x in the expansion of (x + 3)(x + 4) is:", "o": ["12", "7", "1", "4"], "a": 1, "sol": "(x+3)(x+4) = x^2 + 4x + 3x + 12 = x^2 + 7x + 12. The coefficient of x is 7." },
  { "q": "Which identity is best to solve 99^2?", "o": ["(a+b)^2", "(a-b)^2", "(a+b)(a-b)", "x(a+b)"], "a": 1, "sol": "(100 - 1)^2 uses the (a-b)^2 identity." },
  { "q": "What is x^2 - y^2 divided by (x - y)?", "o": ["x - y", "x + y", "xy", "x^2 + y^2"], "a": 1, "sol": "Since (x+y)(x-y) = x^2 - y^2, dividing by (x-y) leaves (x+y)." },
  { "q": "Multiply (x + 0.1) and (x - 0.1).", "o": ["x^2 - 0.1", "x^2 - 0.01", "x^2 - 1", "x^2 + 0.01"], "a": 1, "sol": "x^2 - (0.1)^2 = x^2 - 0.01." },
  { "q": "Find the product: (a - b)(a^2 + ab + b^2).", "o": ["a^3 + b^3", "a^3 - b^3", "a^2 - b^2", "a^3 + 3ab + b^3"], "a": 1, "sol": "This is a standard expansion resulting in the difference of two cubes: a^3 - b^3." },
  { "q": "Multiply 4p^2q by (p - q).", "o": ["4p^3q - 4p^2q^2", "4p^2q - 4pq^2", "4p^3 - 4q^3", "4p^2q^2"], "a": 0, "sol": "4p^2q * p = 4p^3q and 4p^2q * (-q) = -4p^2q^2." },
  { "q": "The product of (x+a)(x+b) is x^2 + (a+b)x + ab. If a=2, b=-3, the result is:", "o": ["x^2 + 5x - 6", "x^2 - x - 6", "x^2 + x - 6", "x^2 - 5x + 6"], "a": 1, "sol": "x^2 + (2-3)x + (2 * -3) = x^2 - x - 6." },
  { "q": "If the side of a square is (x + 1), its area is:", "o": ["x^2 + 1", "2x + 2", "x^2 + 2x + 1", "x^2 - 2x + 1"], "a": 2, "sol": "Area = Side^2 = (x+1)^2 = x^2 + 2x + 1." },
  { "q": "Multiply -x by (-x - y).", "o": ["-x^2 - xy", "x^2 + xy", "x^2 - xy", "-x^2 + xy"], "a": 1, "sol": "-x * -x = x^2 and -x * -y = xy." },
  { "q": "What is the constant term in the product (2x - 5)(3x + 2)?", "o": ["-10", "-3", "10", "4"], "a": 0, "sol": "The constant term is found by multiplying the constants: -5 * 2 = -10." },
  { "q": "Expand (2m - 3n)^2.", "o": ["4m^2 - 9n^2", "4m^2 - 12mn + 9n^2", "4m^2 + 9n^2", "4m^2 - 6mn + 9n^2"], "a": 1, "sol": "(2m)^2 - 2(2m)(3n) + (3n)^2 = 4m^2 - 12mn + 9n^2." },
  { "q": "Find the product: x^2(x + y - z).", "o": ["x^3 + x^2y - x^2z", "x^3 + y - z", "x^2 + xy - xz", "x^3y^2z^2"], "a": 0, "sol": "Distribute x^2 to each term: x^3, x^2y, and -x^2z." },
  { "q": "If we multiply a trinomial by zero, the result is:", "o": ["The trinomial itself", "One", "Zero", "A monomial"], "a": 2, "sol": "Any algebraic expression multiplied by zero is zero." },
  { "q": "Simplify the expression: 5x(x - 2) + 3x^2.", "o": ["8x^2 - 10x", "2x^2 - 10x", "8x^2 - 2", "5x^2 - 10x + 3x^2"], "a": 0, "sol": "5x^2 - 10x + 3x^2 = 8x^2 - 10x." },
  { "q": "The product of (a + b) and (c + d) has how many terms before simplification?", "o": ["2", "4", "3", "1"], "a": 1, "sol": "a(c+d) + b(c+d) = ac + ad + bc + bd (4 terms)." },
  { "q": "What is (10.5)^2 calculated using (a+b)^2?", "o": ["110.25", "100.25", "121.25", "110.5"], "a": 0, "sol": "(10 + 0.5)^2 = 100 + 2(10)(0.5) + 0.25 = 100 + 10 + 0.25 = 110.25." },
  { "q": "Multiply (x + y) by (x^2 - xy + y^2).", "o": ["x^3 - y^3", "x^3 + y^3", "x^2 + y^2", "x^3 + 3xy + y^3"], "a": 1, "sol": "This is the algebraic expansion for the sum of two cubes: x^3 + y^3." },
  { "q": "What is the result of a(b - c) + b(c - a) + c(a - b)?", "o": ["abc", "ab + bc + ca", "0", "2ab + 2bc + 2ca"], "a": 2, "sol": "ab - ac + bc - ba + ca - cb. All terms cancel out to zero." },
  { "q": "Calculate 51 * 52 using (x+a)(x+b) = x^2 + (a+b)x + ab.", "o": ["2652", "2552", "2601", "2502"], "a": 0, "sol": "(50+1)(50+2) = 50^2 + (1+2)50 + (1 * 2) = 2500 + 150 + 2 = 2652." },
  { "q": "In the identity (a-b)^2 = a^2 - 2ab + b^2, if a=x and b=1, we get:", "o": ["x^2 - 1", "x^2 + 1", "x^2 - 2x + 1", "x^2 - x + 1"], "a": 2, "sol": "x^2 - 2(x)(1) + 1^2 = x^2 - 2x + 1." },
  { "q": "Simplify: 2x(3x + 4) - 6x^2.", "o": ["8x", "12x^2", "6x^2 + 8x", "0"], "a": 0, "sol": "6x^2 + 8x - 6x^2 = 8x." },
  { "q": "What is the square of 3x + 4y?", "o": ["9x^2 + 16y^2", "9x^2 + 24xy + 16y^2", "6x^2 + 8y^2", "9x^2 + 12xy + 16y^2"], "a": 1, "sol": "(3x)^2 + 2(3x)(4y) + (4y)^2 = 9x^2 + 24xy + 16y^2." },
  { "q": "Which of these is the correct distribution of l(m + n)?", "o": ["lm + n", "l + mn", "lm + ln", "lmn"], "a": 2, "sol": "The term l must multiply both m and n inside the parentheses." },
  { "q": "Evaluate (a + 1/a)^2.", "o": ["a^2 + 1/a^2", "a^2 + 2 + 1/a^2", "a^2 + 1", "a^2 + 2a + 1"], "a": 1, "sol": "a^2 + 2(a)(1/a) + (1/a)^2 = a^2 + 2 + 1/a^2." },
  { "q": "What is the product of (x-5) and (x-5)?", "o": ["x^2 - 25", "x^2 + 25", "x^2 - 10x + 25", "x^2 - 10x - 25"], "a": 2, "sol": "This is (x-5)^2 = x^2 - 2(x)(5) + 5^2 = x^2 - 10x + 25." },
  { "q": "Find the product of 7a^2 and (a^2 + b^2).", "o": ["7a^4 + 7a^2b^2", "7a^2 + 7b^2", "14a^2 + b^2", "7a^4b^2"], "a": 0, "sol": "7a^2 * a^2 = 7a^4 and 7a^2 * b^2 = 7a^2b^2." },
  { "q": "The product (x+3)(x-3) is equal to:", "o": ["x^2 + 9", "x^2 - 9", "x^2 - 6x + 9", "x^2 - 6"], "a": 1, "sol": "Difference of squares: x^2 - 3^2 = x^2 - 9." },
  { "q": "Expand (1/2 x + 2y)^2.", "o": ["1/4 x^2 + 4y^2", "1/4 x^2 + 2xy + 4y^2", "1/2 x^2 + 4y^2", "1/4 x^2 + xy + 4y^2"], "a": 1, "sol": "(1/2 x)^2 + 2(1/2 x)(2y) + (2y)^2 = 1/4 x^2 + 2xy + 4y^2." },
  { "q": "What is (x-y)^2 + 2xy?", "o": ["x^2 - y^2", "x^2 + y^2", "x^2 + 4xy + y^2", "(x+y)^2"], "a": 1, "sol": "x^2 - 2xy + y^2 + 2xy = x^2 + y^2." },
  { "q": "The expression (a+b)^2 - (a-b)^2 simplifies to:", "o": ["2a^2 + 2b^2", "4ab", "0", "2ab"], "a": 1, "sol": "(a^2+2ab+b^2) - (a^2-2ab+b^2) = 4ab." },
  { "q": "Multiply 3abc by (a + b + c).", "o": ["3a^2bc + 3ab^2c + 3abc^2", "3abc(a+b+c)", "3a + 3b + 3c", "9abc"], "a": 0, "sol": "Distributing 3abc to each term in the trinomial gives 3a^2bc + 3ab^2c + 3abc^2." },
  { "q": "If x + y = 5 and xy = 6, find x^2 + y^2.", "o": ["25", "13", "19", "31"], "a": 1, "sol": "x^2 + y^2 = (x+y)^2 - 2xy = 5^2 - 2(6) = 25 - 12 = 13." },
  { "q": "Multiply (2x + 1) and (3x - 2).", "o": ["6x^2 - x - 2", "6x^2 + x - 2", "6x^2 - 2", "5x - 1"], "a": 0, "sol": "2x(3x-2) + 1(3x-2) = 6x^2 - 4x + 3x - 2 = 6x^2 - x - 2." },
  { "q": "Calculate 95 * 105 using (a-b)(a+b).", "o": ["9975", "10025", "9925", "10000"], "a": 0, "sol": "(100-5)(100+5) = 100^2 - 5^2 = 10000 - 25 = 9975." },
  { "q": "Simplify: (x+y)^2 - 2xy.", "o": ["x^2 + y^2", "x^2 - y^2", "x^2 + 4xy + y^2", "0"], "a": 0, "sol": "x^2 + 2xy + y^2 - 2xy = x^2 + y^2." },
  { "q": "What is the product of any expression and 1?", "o": ["1", "0", "The expression itself", "Its reciprocal"], "a": 2, "sol": "1 is the multiplicative identity." },
  { "q": "Multiply (a/2 - b/3) by 6.", "o": ["3a - 2b", "2a - 3b", "a - b", "6a - 6b"], "a": 0, "sol": "6(a/2) - 6(b/3) = 3a - 2b." },
  { "q": "Expand (x - y - z)^2.", "o": ["x^2 + y^2 + z^2 - 2xy + 2yz - 2xz", "x^2 - y^2 - z^2", "x^2 + y^2 + z^2 - 2xy - 2yz - 2xz", "x^2 + y^2 + z^2"], "a": 0, "sol": "Square each term and add twice the product of every pair." },
  { "q": "In the identity (x+a)(x+b), if x=100, a=3, b=7, the middle term (a+b)x is:", "o": ["1000", "2100", "700", "300"], "a": 0, "sol": "(3+7) * 100 = 10 * 100 = 1000." },
  { "q": "Multiply (x+y) by 0.", "o": ["x+y", "xy", "0", "1"], "a": 2, "sol": "Any expression multiplied by zero results in zero." },
  { "q": "The area of a triangle with base b and height (h+1) is:", "o": ["bh + b", "1/2 bh + 1/2 b", "1/2 b + h", "bh"], "a": 1, "sol": "Area = 1/2 * base * height = 1/2 b(h+1) = 1/2 bh + 1/2 b." },
  { "q": "Find (9.9)^2 using (a-b)^2.", "o": ["98.01", "99.01", "81.81", "98.1"], "a": 0, "sol": "(10 - 0.1)^2 = 100 - 2(10)(0.1) + 0.01 = 100 - 2 + 0.01 = 98.01." },
  { "q": "Multiply (x^2 + y^2) and (x^2 - y^2).", "o": ["x^2 - y^2", "x^4 - y^4", "x^4 + y^4", "x^2 + y^2"], "a": 1, "sol": "(x^2)^2 - (y^2)^2 = x^4 - y^4." },
  { "q": "Simplify: a(b-c) - b(a-c).", "o": ["ab - ac", "bc - ac", "c(b - a)", "0"], "a": 2, "sol": "ab - ac - ba + bc = bc - ac = c(b-a)." },
  { "q": "What is the result of (x+y)(x+y)?", "o": ["x^2 + y^2", "x^2 + 2xy + y^2", "2x + 2y", "x^2 + xy + y^2"], "a": 1, "sol": "This is (x+y)^2 which expands to x^2 + 2xy + y^2." },
  { "q": "Evaluate 103 * 103 using identity.", "o": ["10609", "10906", "10606", "10303"], "a": 0, "sol": "(100+3)^2 = 10000 + 600 + 9 = 10609." },
  { "q": "Simplify p(p-1) + 1.", "o": ["p^2", "p^2 - p + 1", "p^2 + 1", "p-1"], "a": 1, "sol": "Distribute p to get p^2 - p, then add 1." },
  { "q": "The product of (x-1/x) and (x+1/x) is:", "o": ["x^2 - 1/x^2", "x^2 + 1/x^2", "x^2 - 1", "x^2 + 2"], "a": 0, "sol": "Difference of squares identity (a-b)(a+b) = a^2 - b^2." },
  { "q": "What is the degree of the product of two linear expressions?", "o": ["1", "2", "3", "0"], "a": 1, "sol": "Linear (degree 1) * Linear (degree 1) results in Quadratic (degree 2)." },
  { "q": "Multiply xy by (x+y).", "o": ["x^2y + xy^2", "x^2 + y^2", "2xy", "x^2y^2"], "a": 0, "sol": "xy * x = x^2y and xy * y = xy^2." },
  { "q": "If x - 1/x = 4, find x^2 + 1/x^2.", "o": ["16", "18", "14", "20"], "a": 1, "sol": "x^2 + 1/x^2 = (x-1/x)^2 + 2 = 4^2 + 2 = 18." },
  { "q": "Calculate 48 * 52 using (a-b)(a+b).", "o": ["2496", "2504", "2500", "2400"], "a": 0, "sol": "(50-2)(50+2) = 2500 - 4 = 2496." },
  { "q": "Multiply 1/x by (x + x^2).", "o": ["1 + x", "x + x^2", "1 + x^2", "2x"], "a": 0, "sol": "1/x * x = 1 and 1/x * x^2 = x. Result: 1+x." },
  { "q": "Simplify (a+b)^2 + (a-b)^2.", "o": ["2a^2 + 2b^2", "4ab", "a^2 + b^2", "0"], "a": 0, "sol": "(a^2+2ab+b^2) + (a^2-2ab+b^2) = 2a^2 + 2b^2." },
  { "q": "The product of (x-a)(x-b) is:", "o": ["x^2 - (a+b)x + ab", "x^2 + (a+b)x + ab", "x^2 - (a-b)x - ab", "x^2 + ab"], "a": 0, "sol": "x^2 - bx - ax + ab = x^2 - (a+b)x + ab." },
  { "q": "Multiply (x+y+z) by x.", "o": ["x^2 + xy + xz", "x^2 + y + z", "3x + y + z", "xyzx"], "a": 0, "sol": "Each term in the trinomial is multiplied by x." },
  { "q": "Expand (3x - 1)^2.", "o": ["9x^2 - 1", "9x^2 + 1", "9x^2 - 6x + 1", "9x^2 - 3x + 1"], "a": 2, "sol": "(3x)^2 - 2(3x)(1) + 1^2 = 9x^2 - 6x + 1." },
  { "q": "Evaluate 297 * 303.", "o": ["89991", "90000", "89997", "90009"], "a": 0, "sol": "(300-3)(300+3) = 90000 - 9 = 89991." },
  { "q": "What is the product of (a-b) and (b-a)?", "o": ["a^2 - b^2", "-(a-b)^2", "0", "1"], "a": 1, "sol": "(a-b) * [-(a-b)] = -(a-b)^2." },
  { "q": "Simplify x(x+1)(x+2).", "o": ["x^3 + 3x^2 + 2x", "x^3 + 3x + 2", "3x + 3", "x^3 + 2"], "a": 0, "sol": "x(x^2 + 3x + 2) = x^3 + 3x^2 + 2x." },
  { "q": "In the identity (a+b)^2, if a=2x and b=5y, the term 2ab is:", "o": ["10xy", "20xy", "7xy", "40xy"], "a": 1, "sol": "2(2x)(5y) = 20xy." },
  { "q": "Multiply (x^2 - 1) by (x^2 + 1).", "o": ["x^2 - 1", "x^4 - 1", "x^4 + 1", "x^4 - 2x^2 + 1"], "a": 1, "sol": "Difference of squares: (x^2)^2 - 1^2 = x^4 - 1." },
  { "q": "Find (x+2)(x-5).", "o": ["x^2 - 3x - 10", "x^2 + 3x - 10", "x^2 - 7x - 10", "x^2 - 10"], "a": 0, "sol": "x^2 + (-5+2)x + (2 * -5) = x^2 - 3x - 10." },
  { "q": "What is (103)^2?", "o": ["10609", "10906", "10009", "10603"], "a": 0, "sol": "(100+3)^2 = 10000 + 600 + 9 = 10609." },
  { "q": "Multiply 2/3 a by (3a + 6b).", "o": ["2a^2 + 4ab", "2a^2 + 6ab", "2a + 4b", "a^2 + ab"], "a": 0, "sol": "(2/3 a * 3a) + (2/3 a * 6b) = 2a^2 + 4ab." },
  { "q": "Simplify (x+1)^2 - (x-1)^2.", "o": ["4x", "2x^2 + 2", "0", "2x"], "a": 0, "sol": "(x^2+2x+1) - (x^2-2x+1) = 4x." },
  { "q": "The product of (x+y) and (x+y+z) is:", "o": ["x^2 + xy + xz + yx + y^2 + yz", "x^2 + y^2 + z^2", "x^2 + y^2 + xy", "x+y+z"], "a": 0, "sol": "x(x+y+z) + y(x+y+z) = x^2+xy+xz+xy+y^2+yz." },
  { "q": "Calculate 78 * 82 using identity.", "o": ["6396", "6404", "6384", "6400"], "a": 0, "sol": "(80-2)(80+2) = 6400 - 4 = 6396." },
  { "q": "If x + y = 10 and x - y = 4, find x^2 - y^2.", "o": ["14", "40", "100", "16"], "a": 1, "sol": "x^2 - y^2 = (x+y)(x-y) = 10 * 4 = 40." },
  { "q": "What is the result of multiplying (a+b) by 1/ (a+b)?", "o": ["a^2 + b^2", "1", "0", "-1"], "a": 1, "sol": "Any non-zero expression multiplied by its reciprocal is 1." },
  { "q": "Expand (p/q - q/p)^2.", "o": ["p^2/q^2 - 2 + q^2/p^2", "p^2/q^2 + q^2/p^2", "p^2/q^2 - 1 + q^2/p^2", "0"], "a": 0, "sol": "(p/q)^2 - 2(p/q)(q/p) + (q/p)^2 = p^2/q^2 - 2 + q^2/p^2." },
  { "q": "Multiply (x+3) by (x+3).", "o": ["x^2 + 9", "x^2 + 6x + 9", "2x + 6", "x^2 + 3x + 9"], "a": 1, "sol": "Identity (a+b)^2 = a^2 + 2ab + b^2." },
  { "q": "In (x+a)(x+b), if a=5 and b=-5, the product is:", "o": ["x^2 - 25", "x^2 + 10x - 25", "x^2 + 25", "x^2 - 10x - 25"], "a": 0, "sol": "x^2 + (5-5)x + (5 * -5) = x^2 - 25." },
  { "q": "Simplify a^2(b^2 - c^2) + b^2(c^2 - a^2) + c^2(a^2 - b^2).", "o": ["1", "0", "a^2b^2c^2", "a+b+c"], "a": 1, "sol": "All terms cancel out." },
  { "q": "What is the product of (2x) and (0.5x)?", "o": ["x^2", "x", "2.5x", "0.1x^2"], "a": 0, "sol": "2 * 0.5 = 1, so 1x^2." },
  { "q": "Expand (4 - x)^2.", "o": ["16 - x^2", "16 + x^2", "16 - 8x + x^2", "16 - 4x + x^2"], "a": 2, "sol": "4^2 - 2(4)(x) + x^2 = 16 - 8x + x^2." },
  { "q": "Calculate 10.1 * 9.9 using identity.", "o": ["99.99", "100.99", "99.01", "100.01"], "a": 0, "sol": "(10 + 0.1)(10 - 0.1) = 100 - 0.01 = 99.99." },
